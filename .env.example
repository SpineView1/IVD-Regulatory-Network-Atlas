# === Django ===
DJANGO_SECRET_KEY=change-me-to-a-50-char-random-string
DJANGO_ALLOWED_HOSTS=interactome.simbiosys.sb.upf.edu,localhost
DJANGO_SETTINGS_MODULE=interactome.settings.production
DJANGO_CSRF_TRUSTED_ORIGINS=https://interactome.simbiosys.sb.upf.edu
# Sentry environment tag (dev/staging/production); defaults to production if unset.
DJANGO_ENV=production

# === Postgres ===
POSTGRES_DB=interactome
POSTGRES_USER=interactome
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# === Redis ===
REDIS_URL=redis://redis:6379/0

# === MinIO ===
MINIO_ROOT_USER=interactome
MINIO_ROOT_PASSWORD=change-me-to-a-strong-password
MINIO_BUCKET_PAPERS=papers
MINIO_BUCKET_SBML=sbml-artifacts

# === External services ===
AUTHELIA_VERIFY=https://authelia.simbiosys.sb.upf.edu/api/verify

# === Ollama / Authelia credentials ===
OLLAMA_BASE=https://ollama.simbiosys.sb.upf.edu
AUTHELIA_BASE=https://authelia.simbiosys.sb.upf.edu
OLLAMA_USER=set-at-deploy-time
OLLAMA_PASSWORD=set-at-deploy-time
OLLAMA_DEFAULT_TIMEOUT=120
OLLAMA_KEEP_ALIVE=2h
OLLAMA_MAX_LOADED_MODELS=2
OLLAMA_SESSION_COOKIE=
AUTHELIA_SVC_USER=svc-interactome
AUTHELIA_SVC_PASSWORD=change-me

# === NCBI E-utilities ===
NCBI_API_KEY=your-ncbi-api-key
NCBI_CONTACT_EMAIL=francis.chemorion@upf.edu

# === MinIO endpoints ===
MINIO_ENDPOINT_URL=http://minio:9000

# === GROBID ===
GROBID_BASE_URL=http://grobid:8070
GROBID_TIMEOUT=300

# === Observability (Phase 7) ===
# Sentry — set DSN to enable exception capture (leave blank in dev)
SENTRY_DSN_WEB=
SENTRY_DSN_WORKER=
SENTRY_RELEASE=
SENTRY_TRACES_SAMPLE_RATE=0.05
# Prometheus / Grafana
GRAFANA_ADMIN_PASSWORD=change-me-to-a-strong-password
# pgbackrest — host path for backup repository (mounted as volume in docker-compose)
PGBACKREST_REPO_PATH=/var/lib/pgbackrest
# Log shipping — host path for JSON log files (mounted by web/worker containers)
LOG_FILE_PATH=/var/log/interactome/app.jsonl

# === Email (SMTP) — Phase 5 verification notifications ===
DJANGO_DEFAULT_FROM_EMAIL=no-reply@interactome.simbiosys.sb.upf.edu
EMAIL_HOST=smtp.upf.edu
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=true

# --- Neo4j (Phase 8 — derived read-model for crosstalk + GDS analysis) ---
# Postgres remains the system of record; Neo4j is rebuildable from it.
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=changeme-neo4j

# === Entity grounding (Gilda) ===
# Set to the grounding web service to avoid loading Gilda in-process:
# GILDA_GROUNDING_URL=https://grounding.indra.bio/ground
GILDA_GROUNDING_URL=
